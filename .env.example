# ============================================================
# LogiTrack - Configurações de Ambiente
# ============================================================

# Porta do servidor
PORT=3001

# Ambiente (development, production, test)
NODE_ENV=development

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=logitrack
DB_CONNECTION_LIMIT=10

# JSON Web Token
JWT_SECRET=uma_chave_secreta_bem_longa_e_aleatoria
JWT_EXPIRES_IN=24h

# Número de rounds para hash de senha (bcrypt)
BCRYPT_ROUNDS=10